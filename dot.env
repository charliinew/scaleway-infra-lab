# ── Scaleway Credentials ──────────────────────────────────────────────────────
# Get these from: https://console.scaleway.com/identity/api-keys

access_key       = "SCWXXXXXXXXXXXXXXXXX"  # Your Scaleway access key
secret_key       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Your Scaleway secret key
project_id       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # Your project ID

# ── Container Registry ────────────────────────────────────────────────────────
# Name for your container registry namespace (will be created if not exists)

registry_namespace = "onboarding"

# ── Object Storage ────────────────────────────────────────────────────────────
# S3 bucket name (will be created if not exists)

bucket_name = "onboarding-images-prod"

# ── Database Configuration ────────────────────────────────────────────────────
# PostgreSQL credentials (used for initial setup)

db_user     = "onboarding"
db_password = "ChangeMe123!"  # Use a strong password
db_name     = "onboarding"

# ── AI Configuration (Optional) ───────────────────────────────────────────────
# Qwen Vision API for AI alt-text generation

qwen_api_key = "sk-qwen-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # Get from https://platform.qwen.ai
qwen_model   = "qwen-vl-max"  # Model: qwen-vl-plus or qwen-vl-max

# ── SSH Key ───────────────────────────────────────────────────────────────────
# Path to your SSH public key (for bastion access)

ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# ── Infrastructure Sizing ─────────────────────────────────────────────────────
# Adjust based on your needs (default is cost-optimized for development)

kapsule_node_type     = "DEV1-S"  # Node type: DEV1-S, PRO2-XS, etc.
kapsule_pool_size     = 2         # Initial node count
kapsule_pool_min_size = 1         # Minimum nodes (auto-scaling)
kapsule_pool_max_size = 5         # Maximum nodes (auto-scaling)

# ── Environment Variables (for .env file) ─────────────────────────────────────
# These are exported for local development and scripts

ONBOARDING_ACCESS_KEY          = "${access_key}"
ONBOARDING_SECRET_KEY          = "${secret_key}"
ONBOARDING_PROJECT_ID          = "${project_id}"
ONBOARDING_REGISTRY_NAMESPACE  = "${registry_namespace}"
ONBOARDING_BUCKET_NAME         = "${bucket_name}"
ONBOARDING_IMAGE_PROCESSOR_URL = "http://localhost:9090"
ONBOARDING_IMAGE_PROCESSOR_TOKEN = "dev-token-change-in-prod"
QWEN_API_KEY                   = "${qwen_api_key}"

# ── Instructions ──────────────────────────────────────────────────────────────
#
# 1. Copy this file to terraform/terraform.tfvars:
#    cp dot.env terraform/terraform.tfvars
#
# 2. Edit with your actual credentials
#
# 3. For local development, also copy to root .env:
#    cp dot.env .env
#
# 4. Run deployment:
#    make init
#    make deploy
#
# ──────────────────────────────────────────────────────────────────────────────
